{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pstack Memory Episode",
  "type": "object",
  "required": [
    "engagement_id",
    "industry",
    "headliner_use_case",
    "artifacts_reviewed",
    "worked",
    "failed",
    "reusable_lessons"
  ],
  "properties": {
    "engagement_id": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "headliner_use_case": {
      "type": "string"
    },
    "artifacts_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "worked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reusable_lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "target",
          "change",
          "evidence"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "change": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "follow_up_eval_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redaction_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
