{
  "conductor_version": "2.0.0",
  "name": "pstack",
  "display_name": "pstack",
  "tagline": "Turn one deployment strategist into a disciplined multi-agent Palantir delivery team.",
  "description": "Operator-grade AI skill stack for Palantir bootcamps and deployments, spanning discovery, ontology, data, applications, QA, security, deployment, and retrospectives.",
  "repo_url": "https://github.com/myceldigital/pstack",
  "install": {
    "script": "./install.sh",
    "target": "~/.claude/skills/pstack",
    "quick_start": [
      "/bootcamp",
      "/ontology-vision",
      "/pipeline-plan",
      "/ontology-architect"
    ]
  },
  "generated_files": [
    "README.md",
    "docs/skills.md"
  ],
  "audience": {
    "for": [
      "Deployment strategists running AIP bootcamps or compressed phase-zero engagements",
      "Foundry builders who need a disciplined artifact chain across ontology, pipeline, app, and QA work",
      "Operators managing multiple parallel AI sessions and wanting explicit phase gates"
    ],
    "not_for": [
      "Teams looking for a generic prompt pack without phase discipline",
      "Pure software projects with no Foundry, ontology, or Apollo deployment surface",
      "Production changes without a human deployment strategist owning approvals"
    ]
  },
  "phases": [
    {
      "id": "discover",
      "label": "Discover",
      "goal": "Lock the operational problem, customer context, and use-case priority."
    },
    {
      "id": "vision",
      "label": "Vision",
      "goal": "Model the full digital twin and target ontology direction."
    },
    {
      "id": "architecture",
      "label": "Architecture",
      "goal": "Turn the chosen use case into precise ontology and pipeline designs."
    },
    {
      "id": "build",
      "label": "Build",
      "goal": "Stand up data connections, transforms, apps, and agents in parallel."
    },
    {
      "id": "review",
      "label": "Review",
      "goal": "Audit quality, security, and operability before testing."
    },
    {
      "id": "test",
      "label": "Test",
      "goal": "Run end-to-end validation and produce a deployment verdict."
    },
    {
      "id": "ship",
      "label": "Ship",
      "goal": "Deploy safely and enable adoption."
    },
    {
      "id": "reflect",
      "label": "Reflect",
      "goal": "Capture lessons, metrics, and next-phase opportunities."
    },
    {
      "id": "improve",
      "label": "Improve",
      "goal": "Convert engagement evidence into reusable memory, improvement proposals, and gated repo evolution."
    },
    {
      "id": "safety",
      "label": "Safety",
      "goal": "Prevent out-of-scope or destructive changes in customer environments."
    }
  ],
